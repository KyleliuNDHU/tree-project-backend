# .env.example
# 複製此檔案為 .env 並填入實際值

# 資料庫配置（生產環境使用 DATABASE_URL）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tree_data
DB_USER=your_db_user
DB_PASSWORD=your_strong_password_here
# DATABASE_URL=postgresql://user:password@host:port/dbname

# SSL 設定（生產環境建議設為 true）
# DB_SSL_REJECT_UNAUTHORIZED=true

# JWT 配置（生產環境請使用 openssl rand -hex 64 生成強密鑰）
JWT_SECRET=your_strong_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# 伺服器配置
PORT=3000
NODE_ENV=development

# CORS 允許來源（多個用逗號分隔）
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Admin API Token（僅供 /webhook/status 部署診斷使用；admin UI 已改用 JWT）
ADMIN_API_TOKEN=your_admin_token_here

# ML Service 配置
# ML_SERVICE_URL=https://your-ml-service.example.com
# ML_API_KEY=your_ml_api_key_here

# AI API 配置（選擇性設定，未設定則對應功能無法使用）
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
Claude_API_KEY=your_claude_api_key_here
SiliconFlow_API_KEY=your_siliconflow_api_key_here
Alt1_SiliconFlow_API_KEY=your_alt1_key_here
Alt2_SiliconFlow_API_KEY=your_alt2_key_here
Alt3_SiliconFlow_API_KEY=your_alt3_key_here

# PlantNet API（樹種辨識服務）
# 註冊: https://my.plantnet.org/signup
PLANTNET_API_KEY=your_plantnet_api_key_here
