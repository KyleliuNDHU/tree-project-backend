# .env.example

# 資料庫配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tree_data
DB_USER=root  # XAMPP 預設使用者名稱為 root
DB_PASSWORD=  # XAMPP 預設密碼為空，生產環境請設定強密碼

# JWT 配置
JWT_SECRET=your_strong_jwt_secret_key_here # 請生成一個隨機且高強度的密鑰用於生產環境
JWT_EXPIRES_IN=24h

# 伺服器配置
PORT=3000
NODE_ENV=development # 或者 production，取決於預期用途

# 安全配置 
#RATE_LIMIT_WINDOW_MS=600000
#RATE_LIMIT_MAX_REQUESTS=100

# 其他配置
CORS_ORIGIN=http://localhost:5173 # 前端開發伺服器地址，生產環境請修改為您的前端域名

# AI API 配置 (選擇性設定，未設定的 API 對應功能將無法使用)
# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here 

# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here 

# Claude API (Anthropic)
Claude_API_KEY=your_claude_api_key_here 

# SiliconFlow API (支援 Qwen/DeepSeek 模型)
SiliconFlow_API_KEY=your_siliconflow_api_key_here

# API 金鑰輪換追蹤 (選用)
API_KEY_LAST_UPDATED=2024-01-01 